body:not(.dark) .wp-site-blocks p,
body:not(.dark) .wp-site-blocks li,
body:not(.dark) .wp-site-blocks span,
body:not(.dark) .wp-site-blocks strong,
body:not(.dark) .wp-site-blocks em,
body:not(.dark) .wp-site-blocks blockquote,
body:not(.dark) .wp-site-blocks figcaption,
body:not(.dark) .wp-site-blocks label,
body:not(.dark) .wp-site-blocks .wp-block-paragraph,
body:not(.dark) .wp-site-blocks .wp-block-list,
body:not(.dark) .wp-site-blocks .wp-block-quote,
body:not(.dark) .wp-site-blocks .wp-block-table,
body:not(.dark) .wp-site-blocks .wp-block-details,
body:not(.dark) .wp-site-blocks .wp-block-preformatted,
body:not(.dark) .wp-site-blocks .wp-block-code {
