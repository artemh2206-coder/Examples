body.dark .wp-site-blocks h1,
body.dark .wp-site-blocks h2,
body.dark .wp-site-blocks h3,
body.dark .wp-site-blocks h4,
body.dark .wp-site-blocks h5,
body.dark .wp-site-blocks h6,
body.dark .wp-site-blocks .wp-block-heading {
    color: #f3f7ff !important;
