body.dark .wp-site-blocks p,
body.dark .wp-site-blocks li,
body.dark .wp-site-blocks span,
body.dark .wp-site-blocks strong,
body.dark .wp-site-blocks em,
body.dark .wp-site-blocks blockquote,
body.dark .wp-site-blocks figcaption,
body.dark .wp-site-blocks label,
body.dark .wp-site-blocks .wp-block-paragraph,
body.dark .wp-site-blocks .wp-block-list,
body.dark .wp-site-blocks .wp-block-quote,
body.dark .wp-site-blocks .wp-block-table,
body.dark .wp-site-blocks .wp-block-details,
body.dark .wp-site-blocks .wp-block-preformatted,
body.dark .wp-site-blocks .wp-block-code {
